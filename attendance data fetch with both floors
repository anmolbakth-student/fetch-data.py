<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>USMAN ENTERPRISE - Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #1a237e;
            --primary-light: #283593;
            --secondary: #00897b;
            --bg-light: #f5f7fa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #e8eaf6 0%, #f5f7fa 100%);
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 420px;
        }

        .login-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 48px 40px 40px 40px;
            box-shadow: 0 20px 60px rgba(26, 35, 126, 0.15);
            text-align: center;
            transition: transform 0.3s ease;
        }

        .login-card:hover {
            transform: translateY(-4px);
        }

        .logo-icon {
            font-size: 4rem;
            display: block;
            margin-bottom: 8px;
            line-height: 1;
        }

        .company-name {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .company-sub {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 28px;
        }

        .login-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #263238;
            margin-bottom: 24px;
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-group label {
            font-weight: 500;
            font-size: 0.9rem;
            color: #37474f;
            margin-bottom: 6px;
            display: block;
        }

        .form-group .input-group {
            border-radius: 10px;
            overflow: hidden;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
            background: #fafafa;
        }

        .form-group .input-group:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(26, 35, 126, 0.1);
        }

        .form-group .input-group-text {
            background: transparent;
            border: none;
            color: #6c757d;
            padding: 0 0 0 16px;
            font-size: 1.1rem;
        }

        .form-group .form-control {
            border: none;
            padding: 12px 16px 12px 8px;
            font-size: 1rem;
            background: transparent;
            outline: none;
            box-shadow: none;
        }

        .form-group .form-control:focus {
            box-shadow: none;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: #ffffff;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(26, 35, 126, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login i {
            margin-right: 8px;
        }

        .alert-error {
            background: #fef3f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 0.9rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .alert-error i {
            font-size: 1.1rem;
        }

        .footer-text {
            margin-top: 24px;
            font-size: 0.75rem;
            color: #9ca3af;
        }

        .footer-text .footer-logo {
            font-size: 1rem;
        }

        .footer-text .footer-company {
            font-weight: 600;
            color: var(--primary);
        }

        /* Animation */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-card {
            animation: fadeInUp 0.6s ease;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .login-card {
                padding: 32px 20px 28px 20px;
            }
            .logo-icon {
                font-size: 3rem;
            }
            .company-name {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <!-- Logo -->
            <span class="logo-icon">🅐∞🅐</span>
            <div class="company-name">USMAN ENTERPRISE</div>
            <div class="company-sub">Attendance Management System</div>

            <!-- Title -->
            <div class="login-title">
                <i class="bi bi-lock-fill" style="color: var(--primary);"></i> Access Required
            </div>

            <!-- Error Message -->
            {% if error %}
            <div class="alert-error">
                <i class="bi bi-exclamation-triangle-fill"></i>
                {{ error }}
            </div>
            {% endif %}

            <!-- Login Form -->
            <form method="POST" action="{{ url_for('login') }}">
                <div class="form-group">
                    <label for="access_code">
                        <i class="bi bi-key-fill" style="color: var(--primary);"></i> Access Code
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-shield-lock"></i>
                        </span>
                        <input type="password" 
                               class="form-control" 
                               id="access_code" 
                               name="access_code" 
                               placeholder="Enter access code"
                               required
                               autofocus>
                    </div>
                    <small class="text-muted" style="font-size: 0.75rem; margin-top: 4px; display: block;">
                        <i class="bi bi-info-circle"></i> Contact administrator for access
                    </small>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </button>
            </form>

            <!-- Footer -->
            <div class="footer-text">
                <span class="footer-logo">🅐∞🅐</span>
                <span class="footer-company">USMAN ENTERPRISE</span>
                &nbsp;|&nbsp; All Rights Reserved ® 2026
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
{% extends "layout.html" %}

{% block title %}Reports & Statistics{% endblock %}

{% block content %}
<div class="card-modern">
    <div class="card-header-modern">
        <i class="bi bi-bar-chart"></i> Reports & Statistics
    </div>
    <div class="card-body-modern">

        <!-- Tabs Navigation -->
        <ul class="nav nav-tabs nav-tabs-custom mb-4" style="border-bottom: 2px solid #e9ecef;">
            <li class="nav-item">
                <a class="nav-link {% if active_tab == 'summary' %}active{% endif %}" 
                   style="{% if active_tab == 'summary' %}background: #1a237e; color: #ffffff; border-radius: 8px 8px 0 0;{% else %}color: #6c757d;{% endif %} font-weight: 600; padding: 10px 24px; border: none;"
                   href="#summary-tab" data-bs-toggle="tab">
                    <i class="bi bi-clipboard-data"></i> Summary
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="{{ url_for('activity') }}" style="color: #6c757d; font-weight: 600; padding: 10px 24px; border: none;"><i class="bi bi-clock-history"></i> Employee Activity</a>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content">

            <!-- ==================== SUMMARY TAB ==================== -->
            <div class="tab-pane fade {% if active_tab == 'summary' %}show active{% endif %}" id="summary-tab">

                <!-- Summary Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white border-0 shadow-sm">
                            <div class="card-body text-center">
                                <h6 class="card-title text-white-50">Total Users</h6>
                                <h2 class="mb-0">{{ total_users }}</h2>
                                <small>{{ active_users }} active, {{ inactive_users }} inactive</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success text-white border-0 shadow-sm">
                            <div class="card-body text-center">
                                <h6 class="card-title text-white-50">Total Logs</h6>
                                <h2 class="mb-0">{{ total_logs }}</h2>
                                <small>All time records</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-info text-white border-0 shadow-sm">
                            <div class="card-body text-center">
                                <h6 class="card-title text-white-50">Days Covered</h6>
                                <h2 class="mb-0">{{ days_covered }}</h2>
                                <small>{{ date_from }} to {{ date_to }}</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-secondary text-white border-0 shadow-sm">
                            <div class="card-body text-center">
                                <h6 class="card-title text-white-50">Floors</h6>
                                <h2 class="mb-0">{{ floor_users|length }}</h2>
                                <small>Active floors</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Floor Distribution -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-light fw-semibold">
                                <i class="bi bi-building"></i> Users by Floor
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <tr>
                                            <th>Floor</th>
                                            <th>Users</th>
                                            <th>Percentage</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for floor, count in floor_users.items() %}
                                        <tr>
                                            <td>
                                                {% if floor == '2nd_floor' %}
                                                    <span class="badge-floor-2nd">2nd Floor</span>
                                                {% else %}
                                                    <span class="badge-floor-3rd">3rd Floor</span>
                                                {% endif %}
                                            </td>
                                            <td><strong>{{ count }}</strong></td>
                                            <td>
                                                <div class="progress" style="height: 8px; border-radius: 10px;">
                                                    <div class="progress-bar bg-primary" style="width: {{ (count / total_users * 100) if total_users > 0 else 0 }}%; border-radius: 10px;"></div>
                                                </div>
                                                <small class="text-muted">{{ "%.1f"|format((count / total_users * 100) if total_users > 0 else 0) }}%</small>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-light fw-semibold">
                                <i class="bi bi-clipboard-data"></i> Logs by Floor
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <tr>
                                            <th>Floor</th>
                                            <th>Logs</th>
                                            <th>Percentage</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for floor, count in floor_logs.items() %}
                                        <tr>
                                            <td>
                                                {% if floor == '2nd_floor' %}
                                                    <span class="badge-floor-2nd">2nd Floor</span>
                                                {% else %}
                                                    <span class="badge-floor-3rd">3rd Floor</span>
                                                {% endif %}
                                            </td>
                                            <td><strong>{{ count }}</strong></td>
                                            <td>
                                                <div class="progress" style="height: 8px; border-radius: 10px;">
                                                    <div class="progress-bar bg-success" style="width: {{ (count / total_logs * 100) if total_logs > 0 else 0 }}%; border-radius: 10px;"></div>
                                                </div>
                                                <small class="text-muted">{{ "%.1f"|format((count / total_logs * 100) if total_logs > 0 else 0) }}%</small>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Daily Logs (Last 7 Days) -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-light fw-semibold">
                        <i class="bi bi-calendar"></i> Daily Logs (Last 7 Days)
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Total Logs</th>
                                        <th>IN</th>
                                        <th>OUT</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for day in daily_stats %}
                                    <tr>
                                        <td>{{ day.date }}</td>
                                        <td><span class="badge bg-secondary">{{ day.total }}</span></td>
                                        <td><span class="badge bg-success">{{ day.in_count }}</span></td>
                                        <td><span class="badge bg-danger">{{ day.out_count }}</span></td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
            <!-- ==================== END SUMMARY TAB ==================== -->

            

        </div>
    </div>
</div>

<style>
    .nav-tabs-custom .nav-link {
        border: none;
        margin-right: 4px;
        transition: all 0.3s ease;
    }
    .nav-tabs-custom .nav-link:hover {
        background: #e8eaf6;
        border-radius: 8px 8px 0 0;
        color: #1a237e;
    }
    .nav-tabs-custom .nav-link.active {
        background: #1a237e !important;
        color: #ffffff !important;
        border-radius: 8px 8px 0 0;
    }
</style>

<!-- Set active tab based on URL parameter -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const tab = urlParams.get('tab');
        if (tab === 'activity') {
            document.querySelector('#activity-tab').classList.add('show', 'active');
            document.querySelector('#summary-tab').classList.remove('show', 'active');
            document.querySelector('[href="#activity-tab"]').classList.add('active');
            document.querySelector('[href="#summary-tab"]').classList.remove('active');
        }
    });
</script>

{% endblock %}
{% extends "layout.html" %}

{% block title %}Users List{% endblock %}

{% block content %}
<div class="card-modern">
    <div class="card-header-modern">
        <i class="bi bi-people"></i> Users List
        <span class="badge bg-secondary float-end">{{ users|length }} users</span>
    </div>
    <div class="card-body-modern">

        <!-- Filters -->
        <form method="GET" action="/users" class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label fw-semibold"><i class="bi bi-search"></i> Search</label>
                <input type="text" name="search" class="form-control form-control-modern" placeholder="Name or ID..." value="{{ search_query }}">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="bi bi-building"></i> Floor</label>
                <select name="floor" class="form-select form-select-modern">
                    <option value="">All Floors</option>
                    <option value="2nd_floor" {% if selected_floor == '2nd_floor' %}selected{% endif %}>2nd Floor</option>
                    <option value="3rd_floor" {% if selected_floor == '3rd_floor' %}selected{% endif %}>3rd Floor</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="bi bi-toggle-on"></i> Status</label>
                <select name="status" class="form-select form-select-modern">
                    <option value="">All Users</option>
                    <option value="1" {% if selected_status == '1' %}selected{% endif %}>Active</option>
                    <option value="0" {% if selected_status == '0' %}selected{% endif %}>Inactive</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary-custom w-100">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </form>

        <!-- Summary Stats -->
        <div class="row g-2 mb-4">
            <div class="col-md-4">
                <div class="bg-light p-2 rounded-3 text-center">
                    <span class="text-muted small">Total Users</span>
                    <h5 class="mb-0 text-primary">{{ users|length }}</h5>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-light p-2 rounded-3 text-center">
                    <span class="text-muted small">Active</span>
                    <h5 class="mb-0 text-success">{{ active_count }}</h5>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-light p-2 rounded-3 text-center">
                    <span class="text-muted small">Inactive</span>
                    <h5 class="mb-0 text-danger">{{ inactive_count }}</h5>
                </div>
            </div>
        </div>

        <!-- Users Table -->
        {% if users %}
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Floor</th>
                        <th>Status</th>
                        <th>Last Sync</th>
                        <th>Total Logs</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td><strong>{{ user.user_id }}</strong></td>
                        <td>{{ user.name }}</td>
                        <td>
                            {% if user.device_floor == '2nd_floor' %}
                                <span class="badge-floor-2nd">2nd Floor</span>
                            {% else %}
                                <span class="badge-floor-3rd">3rd Floor</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.is_active == 1 %}
                                <span class="badge bg-success" style="padding: 5px 14px; border-radius: 20px;">Active</span>
                            {% else %}
                                <span class="badge bg-secondary" style="padding: 5px 14px; border-radius: 20px;">Inactive</span>
                            {% endif %}
                        </td>
                        <td>{{ user.last_sync or '-' }}</td>
                        <td>
                            <span class="badge bg-primary" style="padding: 5px 12px; border-radius: 20px;">{{ user.log_count or 0 }}</span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="mt-2 text-muted small">
            Showing {{ users|length }} users
        </div>

        {% else %}
        <div class="alert alert-info alert-modern">
            <i class="bi bi-info-circle"></i> No users found matching your filters.
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
