{% block title %}Attendance Records{% endblock %}

{% block content %}
<div class="card-modern">
    <div class="card-header-modern">
        <i class="bi bi-table"></i> Attendance Records
        <span class="badge bg-secondary float-end">{{ total_count }} records</span>
    </div>
    <div class="card-body-modern">

        <!-- Filters -->
        <form method="GET" action="/" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="bi bi-calendar"></i> Date From</label>
                <input type="date" name="date_from" class="form-control form-control-modern" value="{{ date_from }}">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="bi bi-calendar"></i> Date To</label>
                <input type="date" name="date_to" class="form-control form-control-modern" value="{{ date_to }}">
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold"><i class="bi bi-building"></i> Floor</label>
                <select name="floor" class="form-select form-select-modern">
                    <option value="">All Floors</option>
                    <option value="2nd_floor" {% if selected_floor == '2nd_floor' %}selected{% endif %}>2nd Floor</option>
                    <option value="3rd_floor" {% if selected_floor == '3rd_floor' %}selected{% endif %}>3rd Floor</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold"><i class="bi bi-person"></i> User</label>
                <input type="text" name="user_id" class="form-control form-control-modern" placeholder="ID or Name" value="{{ search_user }}">
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary-custom w-100">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </form>

        <!-- Export Buttons -->
        <div class="export-group">
            <a href="{{ url_for('export_excel', date_from=date_from, date_to=date_to, floor=selected_floor, user_id=search_user) }}" 
               class="btn btn-excel">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </a>
            <a href="{{ url_for('export_csv', date_from=date_from, date_to=date_to, floor=selected_floor, user_id=search_user) }}" 
               class="btn btn-csv">
                <i class="bi bi-file-earmark-text"></i> CSV
            </a>
            <a href="{{ url_for('export_pdf', date_from=date_from, date_to=date_to, floor=selected_floor, user_id=search_user) }}" 
               class="btn btn-pdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </a>
            <a href="{{ url_for('export_sheets', date_from=date_from, date_to=date_to, floor=selected_floor, user_id=search_user) }}" 
               class="btn btn-sheets">
                <i class="bi bi-layers"></i> Sheets
            </a>
        </div>

        <!-- Results Table - 10 Columns -->
        {% if logs %}
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th style="min-width: 60px;">ID</th>
                        <th style="min-width: 90px;">Floor</th>
                        <th style="min-width: 100px;">Date</th>
                        <th style="min-width: 90px;">Day</th>
                        <th style="min-width: 120px;">Name</th>
                        <th style="min-width: 90px;">Chk In</th>
                        <th style="min-width: 120px;">Remarks In</th>
                        <th style="min-width: 90px;">Chk Out</th>
                        <th style="min-width: 120px;">Remarks Out</th>
                        <th style="min-width: 200px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                    <tr>
                        <td><strong>{{ log.user_id }}</strong></td>
                        <td>
                            {% if log.device_floor == '2nd_floor' %}
                                <span class="badge-floor-2nd">2nd Floor</span>
                            {% else %}
                                <span class="badge-floor-3rd">3rd Floor</span>
                            {% endif %}
                        </td>
                        <td>{{ log.date }}</td>
                        <td>
                            {% if log.day == 'Sunday' %}
                                <span class="badge bg-danger" style="padding: 4px 12px; border-radius: 20px;">{{ log.day }}</span>
                            {% else %}
                                {{ log.day }}
                            {% endif %}
                        </td>
                        <td>{{ log.user_name }}</td>
                        
                        <!-- Sunday Merged Row -->
                        {% if log.is_sunday %}
                            <td colspan="4" style="text-align: center; background: #f8f9fa; font-weight: bold; color: #dc3545;">
                                {{ log.chk_in }}
                            </td>
                        {% else %}
                            <td>
                                {% if log.chk_in != '--' %}
                                    <span class="badge-in">{{ log.chk_in }}</span>
                                {% else %}
                                    <span class="text-muted">--</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if 'Missing' in log.remark_in %}
                                    <span class="text-danger">{{ log.remark_in }}</span>
                                {% elif log.remark_in %}
                                    <span class="text-success">{{ log.remark_in }}</span>
                                {% else %}
                                    <span class="text-muted">--</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if log.chk_out != '--' %}
                                    <span class="badge-out">{{ log.chk_out }}</span>
                                {% else %}
                                    <span class="text-muted">--</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if 'Missing' in log.remark_out %}
                                    <span class="text-danger">{{ log.remark_out }}</span>
                                {% elif log.remark_out %}
                                    <span class="text-success">{{ log.remark_out }}</span>
                                {% else %}
                                    <span class="text-muted">--</span>
                                {% endif %}
                            </td>
                        {% endif %}
                        
                        <td>
                            {% if log.is_sunday %}
                                <span class="badge bg-secondary" style="padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">
                                    <i class="bi bi-calendar-week"></i> {{ log.status }}
                                </span>
                            {% elif 'Leave' in log.status or 'Absent' in log.status %}
                                <span class="badge bg-danger" style="padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">
                                    <i class="bi bi-exclamation-triangle"></i> {{ log.status }}
                                </span>
                            {% elif 'Missing' in log.status %}
                                <span class="badge bg-warning text-dark" style="padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">
                                    <i class="bi bi-clock"></i> {{ log.status }}
                                </span>
                            {% else %}
                                <span class="badge bg-success" style="padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">
                                    <i class="bi bi-check-circle"></i> {{ log.status }}
                                </span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if total_pages > 1 %}
        <nav class="mt-3">
            <ul class="pagination pagination-custom justify-content-center">
                {% if page > 1 %}
                <li class="page-item">
                    <a class="page-link" href="?page={{ page-1 }}&date_from={{ date_from }}&date_to={{ date_to }}&floor={{ selected_floor }}&user_id={{ search_user }}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                {% endif %}

                {% for p in range(1, total_pages + 1) %}
                    {% if p == page %}
                        <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                    {% elif p <= 3 or p > total_pages - 3 or (p >= page - 2 and p <= page + 2) %}
                        <li class="page-item">
                            <a class="page-link" href="?page={{ p }}&date_from={{ date_from }}&date_to={{ date_to }}&floor={{ selected_floor }}&user_id={{ search_user }}">{{ p }}</a>
                        </li>
                    {% elif p == 4 and page > 5 %}
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    {% endif %}
                {% endfor %}

                {% if page < total_pages %}
                <li class="page-item">
                    <a class="page-link" href="?page={{ page+1 }}&date_from={{ date_from }}&date_to={{ date_to }}&floor={{ selected_floor }}&user_id={{ search_user }}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                {% endif %}
            </ul>
        </nav>
        {% endif %}

        <div class="mt-2 text-muted small">
            Showing {{ logs|length }} records ({{ total_count }} total)
        </div>

        {% else %}
        <div class="alert alert-info alert-modern">
            <i class="bi bi-info-circle"></i> No attendance records found for the selected filters.
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
