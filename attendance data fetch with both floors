<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #1a237e;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f0f0f0;
            padding: 20px;
        }

        .activation-container {
            width: 100%;
            max-width: 400px;
        }

        .activation-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 40px 32px 32px 32px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            text-align: center;
        }

        .logo-icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 4px;
        }

        .company-name {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 20px;
        }

        .activation-title {
            font-size: 1rem;
            font-weight: 600;
            color: #dc3545;
            margin-bottom: 8px;
        }

        .activation-sub {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 24px;
        }

        .form-group {
            margin-bottom: 16px;
            text-align: left;
        }

        .form-group label {
            font-weight: 500;
            font-size: 0.85rem;
            color: #37474f;
            margin-bottom: 4px;
            display: block;
        }

        .form-group .form-control {
            border: 2px solid #e9ecef;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        .form-group .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(26, 35, 126, 0.1);
        }

        .btn-activate {
            width: 100%;
            padding: 12px;
            background: #1a237e;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn-activate:hover {
            background: #0d1442;
            transform: translateY(-1px);
        }

        .alert-error {
            background: #fef3f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .footer-text {
            margin-top: 20px;
            font-size: 0.7rem;
            color: #9ca3af;
        }

        .footer-text .footer-logo {
            font-size: 0.9rem;
        }

        .footer-text .footer-company {
            font-weight: 600;
            color: var(--primary);
        }
    </style>
</head>
<body>
    <div class="activation-container">
        <div class="activation-card">
            <!-- Logo -->
            <span class="logo-icon">🅐∞🅐</span>
            <div class="company-name">USMAN ENTERPRISE</div>

            <!-- Title -->
            <div class="activation-title">
                <i class="bi bi-lock-fill"></i> License Activation
            </div>
            <div class="activation-sub">
                Enter the activation key to continue
            </div>

            <!-- Error Message -->
            {% if error %}
            <div class="alert-error">
                <i class="bi bi-exclamation-triangle-fill"></i>
                {{ error }}
            </div>
            {% endif %}

            <!-- Flash Messages -->
            {% with messages = get_flashed_messages(with_categories=true) %}
                {% if messages %}
                    {% for category, message in messages %}
                        <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert" style="font-size: 0.85rem; padding: 10px 14px;">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" style="font-size: 0.7rem;"></button>
                        </div>
                    {% endfor %}
                {% endif %}
            {% endwith %}

            <!-- Activation Form -->
            <form method="POST" action="{{ url_for('activate') }}">
                <div class="form-group">
                    <label for="key"><i class="bi bi-key-fill"></i> Activation Key</label>
                    <input type="password" 
                           class="form-control" 
                           id="key" 
                           name="key" 
                           placeholder="Enter activation key"
                           required
                           autofocus>
                </div>

                <button type="submit" class="btn-activate">
                    <i class="bi bi-check-circle"></i> Activate
                </button>
            </form>

            <!-- Footer -->
            <div class="footer-text">
                <span class="footer-logo">🅐∞🅐</span>
                <span class="footer-company">USMAN ENTERPRISE</span>
                &nbsp;|&nbsp; All Rights Reserved ® 2026
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
{% extends "layout.html" %}

{% block title %}Employee Activity Report{% endblock %}

{% block content %}
<div class="card-modern">
    <div class="card-header-modern">
        <i class="bi bi-clock-history"></i> Employee Activity Report
        <span class="badge bg-secondary float-end">Detailed punch audit</span>
    </div>
    <div class="card-body-modern">

        <div class="alert alert-info alert-modern mb-4">
            <i class="bi bi-info-circle"></i>
            <strong>Shows every individual punch</strong> - No grouping, no remarks, just raw punch data.
            Each IN and OUT punch appears as a separate row.
        </div>

        <form method="GET" action="{{ url_for('activity') }}" class="filter-row">
            <div class="filter-item">
                <label class="form-label fw-semibold"><i class="bi bi-person"></i> Employee</label>
                <select name="employee" class="form-select form-select-modern" required>
                    <option value="">-- Select Employee --</option>
                    {% for emp in employees %}
                        <option value="{{ emp.user_id }}|{{ emp.device_floor }}"
                                {% if selected_employee == emp.user_id|string + '|' + emp.device_floor %}selected{% endif %}>
                            {{ emp.user_id }} - {{ emp.name }} ({{ emp.device_floor }})
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="filter-item">
                <label class="form-label fw-semibold"><i class="bi bi-calendar"></i> From</label>
                <input type="date" name="date_from" class="form-control form-control-modern"
                       value="{{ date_from_activity or '' }}" required>
            </div>
            <div class="filter-item">
                <label class="form-label fw-semibold"><i class="bi bi-calendar"></i> To</label>
                <input type="date" name="date_to" class="form-control form-control-modern"
                       value="{{ date_to_activity or '' }}" required>
            </div>
            <div class="filter-item-btn">
                <button type="submit" class="btn btn-primary-custom">
                    <i class="bi bi-search"></i> View
                </button>
            </div>
            <div class="filter-item-btn">
                <a href="{{ url_for('activity') }}" class="btn btn-secondary-custom">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </a>
            </div>
        </form>

        {% if activity_logs %}
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Floor</th>
                        <th>Date</th>
                        <th>Day</th>
                        <th>Name</th>
                        <th>Chk In</th>
                        <th>Chk Out</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in activity_logs %}
                    <tr>
                        <td><strong>{{ log.user_id }}</strong></td>
                        <td>
                            {% if log.device_floor == '2nd_floor' %}
                                <span class="badge-floor-2nd">2nd</span>
                            {% else %}
                                <span class="badge-floor-3rd">3rd</span>
                            {% endif %}
                        </td>
                        <td>{{ log.date }}</td>
                        <td>{{ log.day }}</td>
                        <td>{{ log.user_name }}</td>
                        <td>
                            {% if log.punch_type == 0 %}
                                <span class="badge-in">{{ log.time }}</span>
                            {% else %}
                                <span class="text-muted">--</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if log.punch_type == 1 %}
                                <span class="badge-out">{{ log.time }}</span>
                            {% else %}
                                <span class="text-muted">--</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="mt-3 d-flex justify-content-between align-items-center">
            <div>
                <a href="{{ url_for('export_activity', employee=selected_employee, date_from=date_from_activity, date_to=date_to_activity) }}"
                   class="btn btn-excel">
                    <i class="bi bi-file-earmark-excel"></i> Download Excel
                </a>
                <span class="text-muted ms-3" style="font-size: 0.85rem;">
                    <i class="bi bi-list-ul"></i> {{ activity_logs|length }} punches found
                </span>
            </div>
        </div>

        {% else %}
            {% if selected_employee %}
            <div class="alert alert-info alert-modern">
                <i class="bi bi-info-circle"></i> No punches found for the selected employee and date range.
            </div>
            {% else %}
            <div class="alert alert-info alert-modern">
                <i class="bi bi-info-circle"></i> Select an employee and date range to view activity.
            </div>
            {% endif %}
        {% endif %}

    </div>
</div>
{% endblock %}
{% extends "layout.html" %}

{% block title %}Edit Attendance Record{% endblock %}

{% block content %}
<div class="table-container">
    <h2><i class="bi bi-pencil-square"></i> Edit Attendance Record</h2>

    {% if log.is_manually_edited == 1 %}
    <div class="alert alert-warning">
        <i class="bi bi-lock-fill"></i> <strong>This record is manually edited and cannot be modified.</strong>
    </div>
    {% endif %}

    <form method="POST" action="{{ url_for('edit_log', log_id=log.id) }}">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">User ID</label>
                <input type="text" class="form-control" value="{{ log.user_id }}" disabled>
            </div>
            <div class="col-md-6">
                <label class="form-label">User Name</label>
                <input type="text" class="form-control" value="{{ log.user_name }}" disabled>
            </div>
            <div class="col-md-6">
                <label class="form-label">Timestamp</label>
                <input type="text" class="form-control" value="{{ log.timestamp }}" disabled>
            </div>
            <div class="col-md-6">
                <label class="form-label">Floor</label>
                <input type="text" class="form-control" value="{{ log.device_floor }}" disabled>
            </div>
            <div class="col-md-6">
                <label class="form-label">Punch Type</label>
                <input type="text" class="form-control" value="{% if log.punch_type == 0 %}IN{% else %}OUT{% endif %}" disabled>
            </div>
            <div class="col-md-6">
                <label class="form-label">
                    <i class="bi bi-tag"></i> Status
                </label>
                <input type="text" class="form-control" value="{{ log.remark_in or log.remark_out or '-' }}" disabled>
            </div>

            <!-- Editable Fields -->
            <div class="col-md-12">
                <hr>
                <h5 class="text-primary"><i class="bi bi-pencil"></i> Editable Fields</h5>
            </div>

            <div class="col-md-6">
                <label class="form-label">Remark IN</label>
                <input type="text" name="remark_in" class="form-control" 
                       value="{{ log.remark_in or '' }}"
                       {% if log.is_manually_edited == 1 %}disabled{% endif %}>
            </div>

            <div class="col-md-6">
                <label class="form-label">Remark OUT</label>
                <input type="text" name="remark_out" class="form-control" 
                       value="{{ log.remark_out or '' }}"
                       {% if log.is_manually_edited == 1 %}disabled{% endif %}>
            </div>

            <div class="col-md-12">
                <label class="form-label">Status Override</label>
                <input type="text" name="status_override" class="form-control" 
                       value="{{ log.status_override or '' }}"
                       {% if log.is_manually_edited == 1 %}disabled{% endif %}>
                <small class="text-muted">Optional: Override auto-calculated status</small>
            </div>
        </div>

        <div class="mt-4">
            {% if log.is_manually_edited == 0 %}
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
                <button type="reset" class="btn btn-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
            {% else %}
                <div class="alert alert-secondary">
                    <i class="bi bi-lock-fill"></i> This record is locked (manually edited)
                </div>
            {% endif %}
            <a href="{{ url_for('index') }}" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Back to Attendance
            </a>
        </div>
    </form>
</div>
{% endblock %}
{% extends "edit_layout.html" %}

{% block title %}Bulk Edit{% endblock %}

{% block content %}
<div class="card-dull">
    <div class="card-header-dull">
        <i class="bi bi-layers"></i> Bulk Edit Records
        <span class="badge bg-secondary float-end">Update multiple records</span>
    </div>
    <div class="card-body-dull">

        <div class="alert alert-dull">
            <i class="bi bi-info-circle"></i> 
            <strong>How to use:</strong> Select records from the <a href="{{ url_for('edit_list') }}" style="color: #6c757d;">Edit List</a> page, then click "Bulk Edit Selected" to update them all at once.
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card-dull">
                    <div class="card-header-dull">
                        <i class="bi bi-check-square"></i> Step 1: Select Records
                    </div>
                    <div class="card-body-dull">
                        <p style="font-size: 0.85rem; color: #6c757d;">
                            Go to the <a href="{{ url_for('edit_list') }}" style="color: #6c757d;">Edit List</a> page.
                        </p>
                        <ul style="font-size: 0.85rem; color: #6c757d; padding-left: 20px;">
                            <li>Use filters to find records</li>
                            <li>Check the checkbox for each record</li>
                            <li>Click "Bulk Edit Selected" button</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card-dull">
                    <div class="card-header-dull">
                        <i class="bi bi-pencil"></i> Step 2: Update Fields
                    </div>
                    <div class="card-body-dull">
                        <p style="font-size: 0.85rem; color: #6c757d;">
                            In the bulk edit modal, you can update:
                        </p>
                        <ul style="font-size: 0.85rem; color: #6c757d; padding-left: 20px;">
                            <li><strong>Remark IN</strong> - In-time remark</li>
                            <li><strong>Remark OUT</strong> - Out-time remark</li>
                            <li><strong>Status Override</strong> - Custom status</li>
                        </ul>
                        <p style="font-size: 0.85rem; color: #6c757d; margin-top: 8px;">
                            <i class="bi bi-exclamation-triangle"></i> <strong>Note:</strong> Only auto-records (not manually edited) can be updated.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a href="{{ url_for('edit_list') }}" class="btn btn-dull-primary">
                <i class="bi bi-arrow-left"></i> Go to Edit List
            </a>
        </div>

        <hr style="border-color: #dee2e6; margin: 20px 0;">

        <div class="card-dull">
            <div class="card-header-dull">
                <i class="bi bi-clock-history"></i> Recently Updated Records
            </div>
            <div class="card-body-dull">
                {% if recent_edits %}
                <div class="table-responsive">
                    <table class="table table-dull">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Timestamp</th>
                                <th>Floor</th>
                                <th>Remark</th>
                                <th>Edited At</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for edit in recent_edits %}
                            <tr>
                                <td>{{ edit.user_name or edit.user_id }}</td>
                                <td>{{ edit.timestamp }}</td>
                                <td>
                                    <span class="badge-dull-floor">
                                        {% if edit.device_floor == '2nd_floor' %}2nd{% else %}3rd{% endif %}
                                    </span>
                                </td>
                                <td>
                                    {% if edit.remark_in %}
                                        IN: {{ edit.remark_in }}
                                    {% endif %}
                                    {% if edit.remark_out %}
                                        OUT: {{ edit.remark_out }}
                                    {% endif %}
                                </td>
                                <td>{{ edit.last_edited_at or '-' }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <p class="text-muted" style="font-size: 0.85rem;">No recently edited records found.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
