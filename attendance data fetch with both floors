                </div>
            </div>

            <div class="mt-4">
                {% if not is_locked %}
                    <button type="submit" class="btn btn-dull-success">
                        <i class="bi bi-check-lg"></i> Save Changes
                    </button>
                    <button type="reset" class="btn btn-dull-secondary">
                        <i class="bi bi-arrow-counterclockwise"></i> Reset
                    </button>
                {% else %}
                    <div class="alert alert-dull">
                        <i class="bi bi-lock"></i> This record is locked (manually edited)
                    </div>
                {% endif %}
                <a href="{{ url_for('edit_list') }}" class="btn btn-dull-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
