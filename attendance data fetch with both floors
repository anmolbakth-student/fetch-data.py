                <div class="col-md-4">
                    <label class="form-label" style="font-size: 0.8rem; font-weight: 600; color: #6c757d;">Remark OUT</label>
                    <input type="text" name="remark_out" class="form-control form-control-dull" 
                           value="{{ log.remark_out or '' }}"
                           {% if is_locked %}disabled{% endif %}>
