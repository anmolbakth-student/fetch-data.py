{% extends "edit_layout.html" %}

{% block title %}Edit Records{% endblock %}

{% block content %}
<div class="card-dull">
    <div class="card-header-dull">
        <i class="bi bi-pencil"></i> Edit Attendance Records
        <span class="badge bg-secondary float-end">{{ total_count }} records</span>
    </div>
    <div class="card-body-dull">

        <!-- Filters -->
        <form method="GET" action="/edit" class="row g-2 mb-3">
            <div class="col-md-3">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; color: #6c757d;">Search</label>
                <input type="text" name="search" class="form-control form-control-dull" placeholder="ID or Name" value="{{ search }}">
            </div>
            <div class="col-md-2">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; color: #6c757d;">Floor</label>
                <select name="floor" class="form-select form-select-dull">
                    <option value="">All</option>
                    <option value="2nd_floor" {% if floor == '2nd_floor' %}selected{% endif %}>2nd Floor</option>
                    <option value="3rd_floor" {% if floor == '3rd_floor' %}selected{% endif %}>3rd Floor</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; color: #6c757d;">&nbsp;</label>
                <div class="form-check">
                    <input type="checkbox" name="auto_only" value="true" class="form-check-input" id="auto_only" {% if show_only_auto %}checked{% endif %}>
                    <label class="form-check-label" for="auto_only" style="font-size: 0.85rem; color: #6c757d;">
                        Show only auto-records (editable)
                    </label>
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; color: #6c757d;">&nbsp;</label>
                <button type="submit" class="btn btn-dull-primary w-100">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
            <div class="col-md-2">
                <label class="form-label" style="font-size: 0.8rem; font-weight: 600; color: #6c757d;">&nbsp;</label>
                <a href="/edit" class="btn btn-dull-secondary w-100">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </a>
            </div>
        </form>

        <!-- Results Table -->
        {% if logs %}
        <div class="table-responsive">
            <table class="table table-dull">
                <thead>
                    <tr>
                        <th style="width: 50px;">
                            <input type="checkbox" id="select-all" class="form-check-input">
                        </th>
                        <th>ID</th>
                        <th>User</th>
                        <th>Date/Time</th>
                        <th>Floor</th>
                        <th>Type</th>
                        <th>Remark</th>
                        <th>Status</th>
                        <th style="width: 100px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                    <tr>
                        <td>
                            <input type="checkbox" name="record_ids" value="{{ log.id }}" class="form-check-input record-checkbox">
                        </td>
                        <td><strong>{{ log.user_id }}</strong></td>
                        <td>{{ log.user_name or 'Unknown' }}</td>
                        <td>{{ log.timestamp }}</td>
                        <td>
                            <span class="badge-dull-floor">
                                {% if log.device_floor == '2nd_floor' %}2nd{% else %}3rd{% endif %}
                            </span>
                        </td>
                        <td>
                            <span class="badge-dull-type">
                                {% if log.punch_type == 0 %}IN{% else %}OUT{% endif %}
                            </span>
                        </td>
                        <td>
                            {% if log.is_manually_edited == 1 %}
                                <span class="badge-dull-locked"><i class="bi bi-lock"></i> Edited</span>
                            {% endif %}
                            {{ log.remark_in or log.remark_out or '-' }}
                        </td>
                        <td>
                            {% set status = log.remark_in or log.remark_out or '' %}
                            {% if 'ON TIME' in status %}
                                <span class="badge-dull-status">On Time</span>
                            {% elif 'LATE' in status %}
                                <span class="badge-dull-status">Late</span>
                            {% elif 'GRACE' in status %}
                                <span class="badge-dull-status">Grace</span>
                            {% elif 'OVERTIME' in status %}
                                <span class="badge-dull-status">Overtime</span>
                            {% elif 'EARLY' in status %}
                                <span class="badge-dull-status">Early Dept</span>
                            {% else %}
                                <span class="badge-dull-status">-</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if log.is_manually_edited == 0 %}
                                <a href="{{ url_for('edit_single', log_id=log.id) }}" class="btn btn-dull-secondary btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            {% else %}
                                <span class="badge-dull-locked"><i class="bi bi-lock"></i> Locked</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Bulk Edit Button -->
        <div class="mt-2">
            <button type="button" class="btn btn-dull-primary btn-sm" data-bs-toggle="modal" data-bs-target="#bulkEditModal">
                <i class="bi bi-layers"></i> Bulk Edit Selected
            </button>
            <span class="text-muted" style="font-size: 0.8rem; margin-left: 10px;">
                <span id="selected-count">0</span> selected
            </span>
        </div>

        <!-- Pagination -->
        {% if total_pages > 1 %}
        <nav class="mt-3">
            <ul class="pagination pagination-dull justify-content-center">
                {% if page > 1 %}
                <li class="page-item">
                    <a class="page-link" href="?page={{ page-1 }}&search={{ search }}&floor={{ floor }}&auto_only={{ show_only_auto }}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                {% endif %}

                {% for p in range(1, total_pages + 1) %}
                    {% if p == page %}
                        <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                    {% elif p <= 3 or p > total_pages - 3 or (p >= page - 2 and p <= page + 2) %}
                        <li class="page-item">
                            <a class="page-link" href="?page={{ p }}&search={{ search }}&floor={{ floor }}&auto_only={{ show_only_auto }}">{{ p }}</a>
                        </li>
                    {% elif p == 4 and page > 5 %}
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    {% endif %}
                {% endfor %}

                {% if page < total_pages %}
                <li class="page-item">
                    <a class="page-link" href="?page={{ page+1 }}&search={{ search }}&floor={{ floor }}&auto_only={{ show_only_auto }}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                {% endif %}
            </ul>
        </nav>
        {% endif %}

        <div class="mt-2 text-muted" style="font-size: 0.8rem;">
            Showing {{ logs|length }} records ({{ total_count }} total)
        </div>

        {% else %}
        <div class="alert alert-dull">
            <i class="bi bi-info-circle"></i> No records found matching your filters.
        </div>
        {% endif %}
    </div>
</div>

<!-- Bulk Edit Modal -->
<div class="modal fade" id="bulkEditModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 4px; border: 1px solid #dee2e6;">
            <div class="modal-header" style="background: #e9ecef; border-bottom: 1px solid #dee2e6;">
                <h5 class="modal-title" style="color: #495057; font-weight: 600; font-size: 0.95rem;">
                    <i class="bi bi-layers"></i> Bulk Edit
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="{{ url_for('edit_bulk') }}">
                <div class="modal-body">
                    <p style="font-size: 0.85rem; color: #6c757d;">
                        Update <span id="modal-selected-count">0</span> selected record(s)
                    </p>
                    <div class="mb-3">
                        <label class="form-label" style="font-size: 0.85rem; font-weight: 600; color: #495057;">Field to Update</label>
                        <select name="field" class="form-select form-select-dull">
                            <option value="remark_in">Remark IN</option>
                            <option value="remark_out">Remark OUT</option>
                            <option value="status_override">Status Override</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size: 0.85rem; font-weight: 600; color: #495057;">New Value</label>
                        <input type="text" name="value" class="form-control form-control-dull" placeholder="Enter new value">
                    </div>
                    <div id="selected-ids-container"></div>
                </div>
                <div class="modal-footer" style="background: #f8f9fa; border-top: 1px solid #dee2e6;">
                    <button type="button" class="btn btn-dull-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dull-primary">Update All</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% block scripts %}
<script>
    // Select all checkbox
    document.getElementById('select-all').addEventListener('change', function() {
        document.querySelectorAll('.record-checkbox').forEach(cb => cb.checked = this.checked);
        updateSelectedCount();
    });

    // Individual checkboxes
    document.querySelectorAll('.record-checkbox').forEach(cb => {
        cb.addEventListener('change', updateSelectedCount);
    });

    function updateSelectedCount() {
        const selected = document.querySelectorAll('.record-checkbox:checked').length;
        document.getElementById('selected-count').textContent = selected;
        document.getElementById('modal-selected-count').textContent = selected;
        
        // Update hidden inputs for bulk edit
        const container = document.getElementById('selected-ids-container');
        container.innerHTML = '';
        document.querySelectorAll('.record-checkbox:checked').forEach(cb => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'record_ids';
            input.value = cb.value;
            container.appendChild(input);
        });
    }
</script>
{% endblock %}
{% endblock %}
